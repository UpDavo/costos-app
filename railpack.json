{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20"
  },
  "build": {
    "buildCommand": "node scripts/set-env.js && ng build --configuration=production"
  },
  "deploy": {
    "startCommand": "cp /app/nginx.conf /etc/nginx/conf.d/default.conf && rm -f /etc/nginx/sites-enabled/default && nginx -g 'daemon off;'",
    "aptPackages": ["nginx"]
  }
}
